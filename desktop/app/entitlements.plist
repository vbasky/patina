<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    Hardened-runtime exceptions Patina needs to actually run once notarized.
    All are permitted for Developer ID / notarized distribution.
  -->

  <!-- The Rust kernel (evcxr) compiles each cell and dlopen()s the resulting
       unsigned dylib; without this, library validation rejects it. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- The desktop shell passes DYLD_LIBRARY_PATH so the Python kernel loads the
       bundled libpython; hardened runtime strips DYLD_* without this. -->
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>

  <!-- JIT / writable-executable memory for compiled code and the JS engine. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
</dict>
</plist>
